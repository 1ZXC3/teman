# ==================== 应用配置 ====================
APP_NAME=RAG-Knowledge-Base
APP_VERSION=1.0.0
DEBUG=false

# ==================== 数据库 ====================
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=rag_user
MYSQL_PASSWORD=rag_password
MYSQL_DATABASE=rag_knowledge_base

# ==================== Milvus ====================
MILVUS_HOST=milvus-standalone
MILVUS_PORT=19530

# ==================== Redis ====================
REDIS_HOST=redis
REDIS_PORT=6379

# ==================== Embedding 模型 ====================
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
EMBEDDING_DEVICE=cpu

# ==================== 主 LLM (GPT-4o) ====================
PRIMARY_MODEL=gpt-4o
PRIMARY_API_KEY=your-openai-api-key-here
PRIMARY_API_BASE=https://api.openai.com/v1

# ==================== 备选 LLM (DeepSeek) ====================
FALLBACK_MODEL=deepseek-chat
FALLBACK_API_KEY=your-deepseek-api-key-here
FALLBACK_API_BASE=https://api.deepseek.com/v1

# ==================== 安全 ====================
API_AUTH_ENABLED=false
API_AUTH_TOKEN=your-secret-token
ALLOWED_IPS=

# ==================== Token 预算 ====================
TOKEN_BUDGET_DAILY=1000000
TOKEN_BUDGET_MONTHLY=20000000
