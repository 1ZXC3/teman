# ==================== 应用配置 ====================
APP_NAME=RAG-Knowledge-Base
APP_VERSION=1.0.0
DEBUG=false

# ==================== 数据库 ====================
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=rag_user
MYSQL_PASSWORD=rag_password
MYSQL_DATABASE=rag_knowledge_base

# ==================== Milvus ====================
MILVUS_HOST=milvus-standalone
MILVUS_PORT=19530

# ==================== Redis ====================
REDIS_HOST=redis
REDIS_PORT=6379

# ==================== Embedding 模型 ====================
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
EMBEDDING_DEVICE=cpu

# ========== LLM (DeepSeek) ==========
LLM_MODEL=deepseek-chat
LLM_API_KEY=sk-你的deepseek密钥填这里
LLM_API_BASE=https://api.deepseek.com

# ==================== 安全 ====================
API_AUTH_ENABLED=false
API_AUTH_TOKEN=your-secret-token
ALLOWED_IPS=

# ==================== Token 预算 ====================
TOKEN_BUDGET_DAILY=1000000
TOKEN_BUDGET_MONTHLY=20000000
